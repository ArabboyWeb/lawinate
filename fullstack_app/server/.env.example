# Server
NODE_ENV=development
PORT=3001
DATABASE_URL=postgresql://user:password@your-neon-host/your-db?sslmode=require

# URLs
APP_BASE_URL=http://localhost:3000
CLIENT_URL=http://localhost:3000
SERVER_BASE_URL=http://localhost:3001
CORS_ORIGIN=http://localhost:3000,https://your-site.netlify.app

# Auth
JWT_SECRET=replace-with-a-long-random-secret

# AI Provider
OPENROUTER_API_KEY=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/api/auth/google/callback

# Seed accounts (change before production)
ADMIN_SEED_EMAIL=admin@example.com
ADMIN_SEED_PASSWORD=ChangeMe123!
MODERATOR_SEED_EMAIL=moderator@example.com
MODERATOR_SEED_PASSWORD=ChangeMe123!
STUDENT_SEED_PASSWORD=ChangeMe123!
