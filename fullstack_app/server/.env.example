# Server
NODE_ENV=production
PORT=3001
# Optional PostgreSQL health-check URL
DATABASE_URL=postgresql://user:password@your-neon-host/your-db?sslmode=require
# SQLite file path used by app auth/content data
SQLITE_DB_FILE=/var/data/database.db

# URLs
APP_BASE_URL=https://lawinate.uz
CLIENT_URL=https://lawinate.uz
SERVER_BASE_URL=https://lawinate-sc7t.onrender.com
CORS_ORIGIN=https://lawinate.uz,https://www.lawinate.uz,https://lawinate.netlify.app

# Auth
JWT_SECRET=replace-with-a-long-random-secret

# AI Provider
OPENROUTER_API_KEY=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://lawinate-sc7t.onrender.com/api/auth/google/callback

# Seed accounts (change before production)
ADMIN_SEED_EMAIL=admin@example.com
ADMIN_SEED_PASSWORD=ChangeMe123!
MODERATOR_SEED_EMAIL=moderator@example.com
MODERATOR_SEED_PASSWORD=ChangeMe123!
STUDENT_SEED_PASSWORD=ChangeMe123!
