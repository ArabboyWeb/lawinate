# Server
NODE_ENV=production
PORT=3001
# Primary database (Neon/PostgreSQL)
DATABASE_URL=postgresql://user:password@your-neon-host/your-db?sslmode=require
# Optional override: postgres | sqlite
DB_CLIENT=postgres
# Optional SQLite fallback path (used when DB_CLIENT=sqlite or DATABASE_URL missing)
SQLITE_DB_FILE=/var/data/database.db
# Optional one-time migration source for SQLite -> Postgres script
SQLITE_SOURCE_FILE=

# URLs
APP_BASE_URL=https://lawinate.uz
CLIENT_URL=https://lawinate.uz
SERVER_BASE_URL=https://lawinate-sc7t.onrender.com
CORS_ORIGIN=https://lawinate.uz,https://www.lawinate.uz,https://lawinate.netlify.app

# Auth
JWT_SECRET=replace-with-a-long-random-secret

# AI Provider
OPENROUTER_API_KEY=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://lawinate-sc7t.onrender.com/api/auth/google/callback

# Seed accounts (change before production)
ADMIN_SEED_EMAIL=superadmin@lawinate.local
ADMIN_SEED_PASSWORD=LawinateAdmin123!
MODERATOR_SEED_EMAIL=moderator@lawinate.local
MODERATOR_SEED_PASSWORD=LawinateModerator123!
STUDENT_SEED_PASSWORD=LawinateStudent123!
