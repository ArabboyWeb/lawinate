# Server
NODE_ENV=production
PORT=3001
# Primary database (Neon/PostgreSQL)
DATABASE_URL=postgresql://user:password@your-neon-host/your-db?sslmode=require
# App is Neon/PostgreSQL only
DB_CLIENT=postgres

# URLs
APP_BASE_URL=https://lawinate.uz
CLIENT_URL=https://lawinate.uz
SERVER_BASE_URL=https://lawinate-sc7t.onrender.com
CORS_ORIGIN=https://lawinate.uz,https://www.lawinate.uz,https://your-project.vercel.app

# Auth
JWT_SECRET=replace-with-a-long-random-secret

# AI Provider
OPENROUTER_API_KEY=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://lawinate-sc7t.onrender.com/api/auth/google/callback

# Seed accounts (change before production)
ADMIN_SEED_EMAIL=admin@lawinate.local
ADMIN_SEED_PASSWORD=LawinateAdmin123!
ADMIN_SEED_FORCE_SYNC=true
MODERATOR_SEED_EMAIL=moderator@lawinate.uz
MODERATOR_SEED_PASSWORD=LawinateModerator123!
STUDENT_SEED_PASSWORD=LawinateStudent123!
